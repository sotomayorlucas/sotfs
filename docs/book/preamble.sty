% --- listings con estilos para Rust, TLA+, Coq ---
\RequirePackage{listings}

\lstdefinelanguage{rust}{
  morekeywords={fn, let, mut, pub, struct, impl, enum, match, if, else, for,
    while, loop, return, use, mod, crate, self, Self, as, where, trait, type,
    move, ref, async, await, dyn, in, true, false, const, static, unsafe,
    extern},
  morekeywords=[2]{u8, u16, u32, u64, usize, i8, i16, i32, i64, isize, bool,
    str, String, Vec, Option, Result, Box, Arc, Rc, BTreeMap, HashMap},
  morecomment=[l]{//},
  morecomment=[s]{/*}{*/},
  morestring=[b]",
  sensitive=true
}

\lstdefinelanguage{tla}{
  morekeywords={EXTENDS, VARIABLE, VARIABLES, CONSTANT, CONSTANTS, MODULE,
    LET, IN, IF, THEN, ELSE, CHOOSE, EXCEPT, DOMAIN, SUBSET, UNION, ENABLED,
    ASSUME, THEOREM, LEMMA, INSTANCE, WITH, RECURSIVE, UNCHANGED},
  morekeywords=[2]{Init, Next, Spec, Inv, Invariant, TypeOK, Liveness},
  morekeywords=[3]{TRUE, FALSE, BOOLEAN, Nat, Int, Seq, Cardinality},
  morestring=[b]",
  morecomment=[l]{\\\*},
  morecomment=[s]{(*}{*)},
  literate={\\E}{{$\exists$}}1
           {\\A}{{$\forall$}}1
           {\\in}{{$\in$}}1
           {\\notin}{{$\notin$}}1
           {\\cup}{{$\cup$}}1
           {\\cap}{{$\cap$}}1
           {\\subseteq}{{$\subseteq$}}1
           {\\subset}{{$\subset$}}1
           {/\\}{{$\wedge$}}1
           {\\/}{{$\vee$}}1
           {=>}{{$\Rightarrow$}}1
           {<=>}{{$\Leftrightarrow$}}1
           {/=}{{$\neq$}}1
           {->}{{$\to$}}1,
  sensitive=true
}

\lstdefinelanguage{coq}{
  morekeywords={Theorem, Lemma, Proof, Qed, Admitted, Definition, Fixpoint,
    Inductive, Record, Variable, Hypothesis, Parameter, Section, End, Module,
    Require, Import, Export, From, Notation, forall, exists, fun, match,
    with, end, if, then, else, let, in, return, as, Set, Prop, Type, intros,
    induction, destruct, apply, exact, reflexivity, simpl, unfold, rewrite,
    auto, omega, lia, contradiction, discriminate, inversion, split, left,
    right, exists, eauto, firstorder, congruence, subst, assert, pose, fix,
    cofix, struct},
  morecomment=[s]{(*}{*)},
  morestring=[b]",
  sensitive=true
}

\lstdefinelanguage{shellcmd}{
  morecomment=[l]{\#},
  morestring=[b]",
  morestring=[b]'
}

\lstset{
  basicstyle=\ttfamily\small,
  keywordstyle=\color{sotxBlue}\bfseries,
  keywordstyle=[2]\color{sotxTeal},
  keywordstyle=[3]\color{sotxAmber},
