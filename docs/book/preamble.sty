\newunicodechar{★}{$\star$}

% --- \mathit / \mathrm autoswitch a math mode si están en texto ---
% Útil para usarlos dentro de algorithm2e \Return{} sin envolver en $...$.
% unicode-math redefine estos como \protected\def, así que necesitamos
% wrappers nuevos para envolver en $...$ cuando se usan en text mode.
\AtBeginDocument{%
  \let\sotxorigmathit\mathit
  \let\sotxorigmathrm\mathrm
  \let\sotxorigmathsf\mathsf
  \let\sotxorigmathbf\mathbf
  \DeclareRobustCommand{\mathit}[1]{\ensuremath{\sotxorigmathit{##1}}}%
  \DeclareRobustCommand{\mathrm}[1]{\ensuremath{\sotxorigmathrm{##1}}}%
  \DeclareRobustCommand{\mathsf}[1]{\ensuremath{\sotxorigmathsf{##1}}}%
  \DeclareRobustCommand{\mathbf}[1]{\ensuremath{\sotxorigmathbf{##1}}}%
}
