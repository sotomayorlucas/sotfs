}

% --- algorithm2e ---
\RequirePackage[ruled, vlined, linesnumbered, algonl]{algorithm2e}
\SetAlFnt{\small\sffamily}
\SetAlCapFnt{\bfseries\sffamily}
\SetAlCapNameFnt{\sffamily}
\SetCommentSty{\itshape\color{sotxMuted}}
\renewcommand{\algorithmcfname}{Algoritmo}
\renewcommand{\listalgorithmcfname}{Índice de algoritmos}
% Castellanizar palabras clave (algorithm2e no trae locale español)
\SetKwInput{KwIn}{Entrada}
\SetKwInput{KwOut}{Salida}
\SetKw{KwAnd}{y}
\SetKw{KwOr}{o}
\SetKw{KwNot}{no}
\SetKwIF{If}{ElseIf}{Else}{si}{entonces}{sino si}{sino}{fin si}
\SetKwFor{For}{para}{hacer}{fin para}
\SetKwFor{ForEach}{para cada}{hacer}{fin para}
\SetKwFor{While}{mientras}{hacer}{fin mientras}
\SetKwFor{Loop}{repetir}{}{fin repetir}
\SetKwRepeat{Repeat}{repetir}{hasta}
\SetKwBlock{Begin}{inicio}{fin}
\SetKw{Return}{retornar}
\SetKw{KwTo}{a}
\SetKw{KwBy}{paso}
% comentarios fáciles
\newcommand{\comm}[1]{\(\triangleright\) \emph{#1}}

