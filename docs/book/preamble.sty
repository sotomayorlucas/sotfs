% --- encabezados de capítulo limpios ---
\RequirePackage{titlesec}
\titleformat{\chapter}[display]
  {\sffamily\Huge\bfseries\color{sotxBlue}}
  {\filright\sffamily\Large\color{sotxMuted}Capítulo \thechapter}
  {1ex}
  {\titlerule[0.5pt]\vspace{1ex}\filright}
\titlespacing*{\chapter}{0pt}{-30pt}{20pt}

\titleformat{\section}{\sffamily\Large\bfseries\color{sotxFg}}{\thesection}{1em}{}
\titleformat{\subsection}{\sffamily\large\bfseries\color{sotxFg}}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\sffamily\normalsize\bfseries\color{sotxFg}}{}{0pt}{}

% --- header/footer simple ---
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\fancyhead[LE,RO]{\thepage}
\fancyhead[RE]{\nouppercase{\leftmark}}
\fancyhead[LO]{\nouppercase{\rightmark}}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\headrule}{\hbox to\headwidth{\color{sotxRule}\leaders\hrule height \headrulewidth\hfill}}

\fancypagestyle{plain}{%
  \fancyhf{}%
  \fancyfoot[C]{\thepage}%
  \renewcommand{\headrulewidth}{0pt}%
}

