\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{colors}[2026/05/13 sotFS book color palette]

\RequirePackage{xcolor}

% --- paleta principal ---
\definecolor{sotxFg}{HTML}{1F1B16}
\definecolor{sotxBg}{HTML}{FBF9F4}
\definecolor{sotxMuted}{HTML}{6B675E}
\definecolor{sotxRule}{HTML}{C8C1B0}

\definecolor{sotxBlue}{HTML}{1F4E79}
\definecolor{sotxGreen}{HTML}{2D6A4F}
\definecolor{sotxAmber}{HTML}{B7791F}
\definecolor{sotxRed}{HTML}{9E2A2B}
\definecolor{sotxViolet}{HTML}{5C2E91}
\definecolor{sotxTeal}{HTML}{0E7C7B}

% --- variantes claras (fills para nodos) ---
\definecolor{sotxBlueL}{HTML}{D9E5F2}
\definecolor{sotxGreenL}{HTML}{D5E7DD}
\definecolor{sotxAmberL}{HTML}{F4E6C8}
\definecolor{sotxRedL}{HTML}{F2D6D6}
\definecolor{sotxVioletL}{HTML}{E2D6F0}
