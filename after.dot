digraph sotFS {
  rankdir=TB;
  node [fontname="monospace", fontsize=10];
  edge [fontname="monospace", fontsize=8];

  I1 [label="I1\ndir\nlc=1", shape=box, style=filled, fillcolor=gold];
  I2 [label="I2\ndir\nlc=2", shape=box, style=filled, fillcolor=gold];
  D1 [label="D1\nino=1", shape=folder, style=filled, fillcolor=lightyellow];
  D2 [label="D2\nino=2", shape=folder, style=filled, fillcolor=lightyellow];

  D1 -> I1 [label=".", color=black];
  D1 -> I2 [label="foo", color=black];
  D2 -> I2 [label=".", color=black];
  D2 -> I1 [label="..", color=black];
}
