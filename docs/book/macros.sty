\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{macros}[2026/05/13 sotFS book macros]

% --- citas al repositorio (no académicas) ---
\providecommand{\citaTLA}[1]{\texttt{formal/#1}}
\providecommand{\citaCoq}[1]{\texttt{formal/coq/#1}}
\providecommand{\citaCommit}[1]{commit \texttt{#1}}
\providecommand{\citaCrate}[1]{el crate \texttt{#1}}
\providecommand{\citaFile}[1]{\texttt{#1}}
\providecommand{\citaLine}[2]{\texttt{#1:#2}}

% --- DPO triple ---
\providecommand{\dpo}[3]{\ensuremath{#1 \leftarrow #2 \rightarrow #3}}
\providecommand{\dpoL}{L}
\providecommand{\dpoK}{K}
\providecommand{\dpoR}{R}

% --- referencias cruzadas a cajas ---
\providecommand{\invref}[1]{invariante~\ref{#1}}
\providecommand{\trampref}[1]{trampa~\ref{#1}}
\providecommand{\ejref}[1]{ejercicio~\ref{#1}}
\providecommand{\defnref}[1]{definición~\ref{#1}}
\providecommand{\teoref}[1]{teorema~\ref{#1}}
\providecommand{\lemref}[1]{lema~\ref{#1}}

% --- conjuntos y notación habitual ---
\providecommand{\NN}{\mathbb{N}}
